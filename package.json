{
  "name": "expouitv",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "postinstall": "patch-package",
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "reset-project": "./scripts/reset-project.js",
    "lint": "expo lint",
    "prebuild:tv": "EXPO_TV=1 expo prebuild --clean",
    "prebuild": "expo prebuild --clean",
    "deploy": "npx expo export -p web && npx eas-cli@latest deploy"
  },
  "dependencies": {
    "@expo/html-elements": "^0.12.5",
    "@expo/metro-runtime": "~55.0.6",
    "@expo/ui": "~55.0.0-preview.6",
    "@expo/vector-icons": "^15.0.2",
    "expo": "^55.0.0-preview.11",
    "expo-build-properties": "~55.0.7",
    "expo-constants": "~55.0.5",
    "expo-dev-client": "~55.0.6",
    "expo-file-system": "~55.0.6",
    "expo-font": "~55.0.4",
    "expo-linking": "~55.0.4",
    "expo-router": "~55.0.0-preview.8",
    "expo-splash-screen": "~55.0.6",
    "expo-status-bar": "~55.0.3",
    "expo-system-ui": "~55.0.6",
    "expo-video": "~55.0.6",
    "expo-web-browser": "~55.0.6",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "npm:react-native-tvos@0.83-stable",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-reanimated": "~4.2.1",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-web": "^0.21.0",
    "react-native-worklets": "0.7.2"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@react-native-tvos/config-tv": "^0.1.5",
    "@types/react": "~19.2.2",
    "eslint": "^9.0.0",
    "eslint-config-expo": "~55.0.0",
    "patch-package": "^8.0.0",
    "postinstall-postinstall": "^2.1.0",
    "typescript": "~5.9.2"
  },
  "expo": {
    "install": {
      "exclude": [
        "react-native"
      ]
    }
  },
  "private": true
}
