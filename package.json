{
  "name": "expouitv",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "postinstall": "patch-package",
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "reset-project": "./scripts/reset-project.js",
    "lint": "expo lint",
    "prebuild:tv": "EXPO_USE_PRECOMPILED_MODULES=0 EXPO_TV=1 expo prebuild --clean",
    "prebuild": "expo prebuild --clean",
    "deploy": "npx expo export -p web && npx eas-cli@latest deploy"
  },
  "dependencies": {
    "@expo/dom-webview": "^56.0.4",
    "@expo/html-elements": "^0.12.5",
    "@expo/material-symbols": "^0.1.1",
    "@expo/metro-runtime": "~56.0.8",
    "@expo/ui": "~56.0.8",
    "@expo/vector-icons": "^15.0.2",
    "expo": "56.0.0-preview.12",
    "expo-build-properties": "~56.0.9",
    "expo-codemod": "^56.0.1",
    "expo-constants": "~56.0.11",
    "expo-dev-client": "~56.0.11",
    "expo-file-system": "~56.0.5",
    "expo-font": "~56.0.4",
    "expo-linear-gradient": "~56.0.4",
    "expo-linking": "~56.0.8",
    "expo-router": "~56.2.1",
    "expo-splash-screen": "~56.0.7",
    "expo-status-bar": "~56.0.4",
    "expo-system-ui": "~56.0.4",
    "expo-video": "~56.1.1",
    "expo-web-browser": "~56.0.4",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "npm:react-native-tvos@0.85-stable",
    "react-native-gesture-handler": "~2.31.1",
    "react-native-reanimated": "~4.3.1",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "~4.25.0",
    "react-native-web": "^0.21.0",
    "react-native-worklets": "0.8.3"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@react-native-tvos/config-tv": "^0.1.5",
    "@types/react": "~19.2.2",
    "eslint": "^9.0.0",
    "eslint-config-expo": "~56.0.4",
    "patch-package": "^8.0.0",
    "postinstall-postinstall": "^2.1.0",
    "typescript": "~6.0.3"
  },
  "expo": {
    "install": {
      "exclude": [
        "react-native"
      ]
    }
  },
  "private": true
}
